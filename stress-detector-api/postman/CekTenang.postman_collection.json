      "item": [
        {
          "name": "Submit Activity",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Extract activity_id\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.data && jsonData.data.activity && jsonData.data.activity.id) {",
                  "        pm.environment.set(\"activity_id\", jsonData.data.activity.id);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = new Date();",
                  "const pad = (n) => n < 10 ? '0'+n : n;",
                  "const dateStr = d.getFullYear() + '-' + pad(d.getMonth()+1) + '-' + pad(d.getDate());",
                  "pm.environment.set('current_date', dateStr);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"activityDate\": \"{{current_date}}\",\n  \"sleepHours\": 7,\n  \"studyHours\": 6,\n  \"screenTimeHours\": 4,\n  \"socialMediaHours\": 2,\n  \"physicalActivityMinutes\": 30,\n  \"caffeineIntakeMg\": 200,\n  \"moodScore\": 6,\n  \"fatigueLevel\": 5,\n  \"assignmentLoad\": 3,\n  \"deadlinePressure\": 7,\n  \"socialInteractionScore\": 5,\n  \"financialWorryScore\": 4,\n  \"healthConditionScore\": 8\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/activities",
              "host": [
                "{{base_url}}"
